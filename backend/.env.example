DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/verdimobility
JWT_SECRET=changeme32charsminimumchangeme32charsminimum
JWT_REFRESH_SECRET=changeme32charsminimumchangeme32charsminimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
BCRYPT_ROUNDS=12
PORT=4000

# Optional: enable distance lookups and impact estimates
GOOGLE_MAPS_API_KEY=your_key_here
MATCHING_SCORER=v1
VEHICLE_L_PER_100KM=8
